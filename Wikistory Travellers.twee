:: StoryStylesheet [stylesheet]
@import url('https://fonts.googleapis.com/css2?family=MedievalSharp&family=Modern+Antiqua&display=swap');


tw-story {
    background-color: Wheat;
    color: black;
  	font-family: "Modern Antiqua";
}

